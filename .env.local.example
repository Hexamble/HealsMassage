# heals-system-rebuild — environment template
#
# Copy this file to `.env.local` and fill in the values printed by
# `supabase status` after running `supabase start`. All four variables below
# are required; the app validates them at boot via `src/lib/env.ts` and will
# refuse to start if any are missing or empty.
#
# Variable summary:
#   1. NEXT_PUBLIC_SUPABASE_URL       — base URL of the Supabase API.
#                                       Safe to ship to the browser (NEXT_PUBLIC_*).
#   2. NEXT_PUBLIC_SUPABASE_ANON_KEY  — anonymous public JWT used by the browser.
#                                       Subject to Row-Level Security; safe to ship.
#   3. SUPABASE_SERVICE_ROLE_KEY      — server-only key that BYPASSES RLS.
#                                       NEVER prefix with NEXT_PUBLIC_.
#                                       NEVER ship to the browser.
#                                       Used only by Server Actions (e.g. EXTRA
#                                       mirror writes) and the legacy CSV
#                                       migration tool.
#   4. CRON_SECRET                    — shared secret for the Vercel Cron
#                                       snapshot route (/api/cron/snapshot).
#                                       Server-only.

# 1. Local Supabase URL — after `supabase start` this is http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# 2. Anon public key from `supabase status` (line: "anon key")
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-key-from-supabase-status

# 3. Service role key from `supabase status` (line: "service_role key").
#    SERVER-ONLY. Bypasses RLS. Do not expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key-from-supabase-status

# 4. Shared secret for the Vercel Cron snapshot route (/api/cron/snapshot).
#    Vercel auto-generates this when you create a cron project; set it to any
#    strong random string for local testing. The cron route rejects requests
#    whose Authorization header doesn't match `Bearer <CRON_SECRET>`.
CRON_SECRET=replace-with-a-strong-random-secret
