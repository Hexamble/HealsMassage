{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3100 -H 127.0.0.1",
    "dev:port": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest --runInBand",
    "test:domain": "jest --runInBand --testPathPattern=src/domain",
    "test:integration": "jest --runInBand --testPathPattern=tests/integration",
    "test:property": "jest --runInBand --testPathPattern=property",
    "typecheck": "tsc --noEmit",
    "migrate": "tsx -r dotenv/config src/migration/cli.ts dotenv_config_path=.env.local",
    "seed:prices": "tsx -r dotenv/config scripts/seed-prices.ts dotenv_config_path=.env.local",
    "seed:rates": "tsx -r dotenv/config scripts/seed-commission-rates.ts dotenv_config_path=.env.local",
    "seed:settings": "tsx -r dotenv/config scripts/seed-settings.ts dotenv_config_path=.env.local",
    "seed:staff": "tsx -r dotenv/config scripts/seed-staff.ts dotenv_config_path=.env.local",
    "seed:users": "tsx -r dotenv/config scripts/seed-users.ts dotenv_config_path=.env.local",
    "db:push": "tsx -r dotenv/config scripts/db-push.ts dotenv_config_path=.env.local",
    "seed:all": "cross-env DOTENV_CONFIG_PATH=.env.local tsx -r dotenv/config scripts/seed-all-rest.ts dotenv_config_path=.env.local",
    "seed:all:prod": "cross-env DOTENV_CONFIG_PATH=.env.production.local tsx -r dotenv/config scripts/seed-all-rest.ts dotenv_config_path=.env.production.local",
    "verify:schema:prod": "tsx -r dotenv/config scripts/verify-schema.ts dotenv_config_path=.env.production.local",
    "verify:seed:prod": "tsx -r dotenv/config scripts/verify-seed.ts dotenv_config_path=.env.production.local",
    "setup": "tsx -r dotenv/config scripts/setup.ts dotenv_config_path=.env.local",
    "verify:schema": "tsx -r dotenv/config scripts/verify-schema.ts dotenv_config_path=.env.local",
    "verify:seed": "tsx -r dotenv/config scripts/verify-seed.ts dotenv_config_path=.env.local"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.105.4",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.2.0",
    "idb": "8.0.3",
    "next": "14.2.35",
    "papaparse": "^5.5.3",
    "react": "^18",
    "react-dom": "^18",
    "server-only": "^0.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.41",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "fake-indexeddb": "^6.2.5",
    "fast-check": "^3.23.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.4.1",
    "pg": "^8.21.0",
    "pg-protocol": "^1.14.0",
    "pg-types": "^4.1.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.1",
    "typescript": "^5"
  }
}
